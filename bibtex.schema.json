{   
    "$id": "https://minhhvo.github.io/schemas/bibtex.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    
    "title": "Modified BibTex Entry Data Transfer Object (DTO) Schema",
    "description": "Representation of all BibTex entry types",
    "deprecated": true,
    
    "type": "object",
    "required": ["class", "citeKey", "fields"],
    "properties": {
        "citeKey":{
            "type": "string",
            "description": "The primary key (metakey) within a bibliography being used to uniquely identify a citation entry.",
            "pattern": "^[a-zA-Z]+[0-9]{4}[a-z]?$"
        },
        "class": {
            "$ref": "#/$defs/entryType", "type": "string",
            "description": "The type of creative work being included in the bibliography. This is a required field, and must be one of the BibTex entry types."
        },

        "fields": { 
            "type": "object", 
            "description": "The payload container for BibTeX domain data. The specific allowed fields, required properties, and data types are dynamically delegated based on the evaluated entry class.",
            "minProperties": 1,
            "unevaluatedProperties": false
        }
    },

    "allOf": [
        {
            "if": { "properties": { "class": { "const": "article" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@article" } } }
        },
        {
            "if": { "properties": { "class": { "const": "book" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@book" } } }
        },
        {
            "if": { "properties": { "class": { "const": "booklet" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@booklet" } } }
        },
        {
            "if": { "properties": { "class": { "const": "inbook" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@inbook" } } }
        },
        {
            "if": { "properties": { "class": { "const": "incollection" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@incollection" } } }
        },
        {
            "if": { "properties": { "class": { "const": "inproceedings" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@inproceedings" } } }
        },
        {
            "if": { "properties": { "class": { "const": "conference" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@conference" } } }
        },
        {
            "if": { "properties": { "class": { "const": "manual" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@manual" } } }
        },
        {
            "if": { "properties": { "class": { "const": "mastersthesis" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@mastersthesis" } } }
        },
        {
            "if": { "properties": { "class": { "const": "phdthesis" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@phdthesis" } } }
        },
        {
            "if": { "properties": { "class": { "const": "misc" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@misc" } } }
        },
        {
            "if": { "properties": { "class": { "const": "proceedings" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@proceedings" } } }
        },
        {
            "if": { "properties": { "class": { "const": "techreport" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@techreport" } } }
        },
        {
            "$comment":"<Placeholder for missing subschema> BibTeX supports and provide a model for `unpublished`, which would fit the entry model where `CFFkey == 'personal-communication'`.",
            "description": "Incomplete / Boilerplate",
            "if": { "properties": { "class": { "const": "unpublished" } } },
            "then": { "properties": { "fields": { "$ref": "#/$defs/@misc" } } }
        },

        {
        "if": { 
            "properties": { 
                "class": { 
                    "not": { 
                        "enum": [
                            "article", "book", "booklet", "inbook", 
                            "incollection", "inproceedings", "conference", 
                            "manual", "mastersthesis", "phdthesis", 
                            "misc", "proceedings", "techreport"
                        ] 
                    } 
                } 
            } 
        },
        "then": { 
            "properties": { "fields": { "$ref": "#/$defs/@misc" } } 
        }
        }
    ],

    "$defs": {
        "entryType": {
            "type": "string",
            "enum": [ 
                "article", "book", "booklet",
                "inproceedings", "conference",
                "inbook", "incollection", "manual",
                "mastersthesis", "phdthesis", "misc",
                "proceedings", "techreport", "unpublished",
                "dataset", "database", "software",
                "online", "video", "website", "blog",
                "personal-communication", "patent"
            ]
        },

        "F_key": {
            "type": "string",
            "description": "Used for alphabetizing, cross referencing, and creating a label when the “author” information is missing. This field SHOULD not be confused with the key that appears at the beginning of the database entry."
        },
        "F_type": {
            "type": "string",
            "description": "a string that describes the type of media/creative work being referenced, such as 'article', 'book', 'inproceedings', etc."
        },
        "F_annote": {
            "type": "string",
            "description": "It is not used by the standard bibliography styles, but may be used by others that produce an annotated bibliography."
        },
        "F_authors": {
            "type": "array",
            "description": "An ordered list of author(s) accredited with authorships of the creative work.",
            "items": { "$ref": "#/$defs/author" }
        },
        "F_title": {
            "type": "string",
            "description": "The title of the work."
        },
        "F_collectionTitle": {
            "type": "string",
            "description": "The title of a collection of published works, such as a book (`@BOOK`) or a periodical journal issues (`@ARTICLE`)."
        },
        "F_chapter": {
            "type": ["string", "integer"],
            "description": "The chapter number of the work, if applicable."
        },
        "F_crossref"  : {
            "type": "string",
            "description": "The database key of the entry being cross-referenced."
        },
        "F_journal": {
            "type": "string",
            "description": "The name of the journal in which the work was published.",
            "$comment": "FUTURE: Consider (a) creating a pattern for discriminating between string that are abbreviated and full journal names, (b) a small (self-hosted) database of journal names and their abbreviations, and (c) a subschema for journal name validation."
        },
        "F_year": {
            "type": ["string", "integer"],
            "description": "Year of Publication or, for an unpublished work, the year it was written / submitted.",
            "$comment": "recommend type-casting to string for consistency with standard BibTex, but acceptable to use integer type for interoperability with external APIs."
        },
        "F_volume": {
            "type": ["string", "integer"],
            "description": "The volume of the journal in which the work was published."
        },
        "F_issueNumber": {
            "type": ["string", "integer"],
            "description": "The issue number of the journal in which the work was published."
        },
        "F_pages": {
            "type": ["string", "integer"],
            "description": "The page numbers of the work."
        },
        "F_eid": {
            "type": "string",
            "description": "Electronic article identifier (eid) used in place of pages for online-only journals"
        },
        "F_month": {
            "type": ["string", "integer"],
            "description": "The month of publication or, for an unpublished work, the month of it was written / submitted."
        },
        "F_publisher": {
            "type": "string",
            "description": "The name of the publisher."
        },
        "F_address": {
            "type": "string",
            "description": "Usually the address of the publisher or other type of institution.",
            "$comment": "FUTURE: Use tuple validation and create a schema (via abstraction) for address to optimize validation and data transfers across different APIs."
        },
        "F_edition": {
            "type": ["string", "integer"],
            "description": "The edition of the work."
        },
        "F_editors": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "The editor(s) of the work.",
            "$comment": "This is an array of the editor(s) of the work. @FUTURE - Consider changing this to an array of author while allowing for a single string representation of the editor(s) to account for pseudonyms and mononyms of anonymous, journal-appointed editors."
        },
        "F_series": {
            "type": "string",
            "description": "The series to which the work belongs."
        },
        "F_howpublished": {
            "type": "string",
            "description": "How the work was published? / The medium where the work was published (e.g., 'Online', 'In press').",
            "$comment":"FUTURE: Referencing the APA7 acceptable mediums for publications or cited works, and create a subschema (enumerated) to replace `type: string`.",
            
            "default": "Online"
        },
        "F_institution": {
            "type": "string",
            "description": "The institution where the work was published."
        },
        "F_organization": {
            "type": "string",
            "description": "The organization associated with the work."
        },
        "F_school": {
            "type": "string",
            "description": "The school where the work was published."
        },
        "F_note":{
            "type": "string",
            "description": "Additional notes (from the bibliographic database owner/users) about the work."
        },
        "F_webIdentifier": {
            "anyOf": [{"$ref": "#/$defs/doi"}, {"$ref": "#/$defs/url"}],
            "description": "A web-based identifier for the work, such as a DOI or URL."
        },

        "@article": {
            "type": "object",
            "title": "@ARTICLE sub-schema",
            "description": "`@ARTICLE` entries' data model.",
    
            "properties": {
                "authors": { "$ref": "#/$defs/F_authors" },
                "journal": { "$ref": "#/$defs/F_journal" },
                "title": { "$ref": "#/$defs/F_title" },
                "type": { "$ref": "#/$defs/F_type" },
                "year": { "$ref": "#/$defs/F_year" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },

                "annote": { "$ref": "#/$defs/F_annote" },
                "chapter": { "$ref": "#/$defs/F_chapter" },
                "collectionTitle": { "$ref": "#/$defs/F_collectionTitle" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "editors": { "$ref": "#/$defs/F_editors" },
                "eid": { "$ref": "#/$defs/F_eid" },
                "howpublished": { "$ref": "#/$defs/F_howpublished" },
                "institution": { "$ref": "#/$defs/F_institution" },
                "issueNumber": { "$ref": "#/$defs/F_issueNumber" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "organization": { "$ref": "#/$defs/F_organization" },
                "pages": { "$ref": "#/$defs/F_pages" },
                "publisher": { "$ref": "#/$defs/F_publisher" },
                "series": { "$ref": "#/$defs/F_series" },
                "volume": { "$ref": "#/$defs/F_volume" }
            },
            "required": ["authors", "title", "journal", "year", "webIdentifier"],
            "anyOf": [
                { "required": ["pages"] },
                { "required": ["eid"] }
            ]
        },
        "@book": {
            "type": "object",
            "title": "@BOOK sub-schema",
            "description": "`@BOOK` entries' data model.",

            "properties": {
                "title": { "$ref": "#/$defs/F_title" },
                "type": { "$ref": "#/$defs/F_type" },
                "year": { "$ref": "#/$defs/F_year" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },

                "address": { "$ref": "#/$defs/F_address" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "annote": { "$ref": "#/$defs/F_annote" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "editors": { "$ref": "#/$defs/F_editors" },
                "edition": { "$ref": "#/$defs/F_edition" },
                "issueNumber": { "$ref": "#/$defs/F_issueNumber" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "publisher": { "$ref": "#/$defs/F_publisher" },
                "series": { "$ref": "#/$defs/F_series" },
                "volume": { "$ref": "#/$defs/F_volume" }
            },
            "required": ["title", "publisher", "year"],
            
            "anyOf": [
                { "required": ["authors"] },
                { "required": ["editors"] }
            ]
        },
        "@inbook": {
            "type": "object",
            "title": "@INBOOK sub-schema",
            "description": "`@INBOOK` entries' data model.",

            "properties": {
                "address": { "$ref": "#/$defs/F_address" },
                "annote": { "$ref": "#/$defs/F_annote" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "chapter": { "$ref": "#/$defs/F_chapter" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "edition": { "$ref": "#/$defs/F_edition" },
                "editors": { "$ref": "#/$defs/F_editors" },
                "issueNumber": { "$ref": "#/$defs/F_issueNumber" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "pages": { "$ref": "#/$defs/F_pages" },
                "publisher": { "$ref": "#/$defs/F_publisher" },
                "series": { "$ref": "#/$defs/F_series" },
                "title": { "$ref": "#/$defs/F_title" },
                "type": { "$ref": "#/$defs/F_type" },
                "volume": { "$ref": "#/$defs/F_volume" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },
                "year": { "$ref": "#/$defs/F_year" }
            },

            "required": ["title", "publisher", "year"],
            
            "allOf": [
                {
                    "anyOf": [
                        { "required": ["authors"] },
                        { "required": ["editors"] }
                    ]
                },
                {
                    "anyOf": [
                        { "required": ["chapter"] },
                        { "required": ["pages"] }
                    ]
                }
            ]
        },
        "@booklet": {
            "type": "object",
            "title": "@BOOKLET sub-schema",
            "description": "`@BOOKLET` entries' data model.",
            "properties": {
                "address": { "$ref": "#/$defs/F_address" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "chapter": { "$ref": "#/$defs/F_chapter" },
                "edition": { "$ref": "#/$defs/F_edition" },
                "howpublished": { "$ref": "#/$defs/F_howpublished" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "pages": { "$ref": "#/$defs/F_pages" },
                "publisher": { "$ref": "#/$defs/F_publisher" },
                "title": { "$ref": "#/$defs/F_title" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" }
            },
            "required": ["title"],
            "anyOf": [ { "required": ["howpublished"] }, { "required": ["webIdentifier"] } ]  
        },
        "@inproceedings": {
            "type": "object",
            "title": "@INPROCEEDINGS sub-schema",
            "description": "`@INPROCEEDINGS` entry data model for formally published conference proceedings papers.",
            "$comment": "@PROTOTYPE: Either 'howpublished' or 'webIdentifier' must be present for APA7 compliance.",
            "properties": {
                "address": { "$ref": "#/$defs/F_address" },
                "annote": { "$ref": "#/$defs/F_annote" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "collectionTitle": { "$ref": "#/$defs/F_collectionTitle" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "edition": { "$ref": "#/$defs/F_edition" },
                "editors": { "$ref": "#/$defs/F_editors" },
                "institution": { "$ref": "#/$defs/F_institution" },
                "issueNumber": { "$ref": "#/$defs/F_issueNumber" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "organization": { "$ref": "#/$defs/F_organization" },
                "pages": { "$ref": "#/$defs/F_pages" },
                "publisher": { "$ref": "#/$defs/F_publisher" },
                "title": { "$ref": "#/$defs/F_title" },
                "type": { 
                    "$ref": "#/$defs/F_type",
                    "default": "Conference proceedings paper",
                    "description": "Clarifies the publication format (e.g., 'Conference proceedings paper') for CFF and CSL cross-platform mapping."
                },
                "volume": { "$ref": "#/$defs/F_volume" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },
                "year": { "$ref": "#/$defs/F_year" }
            },
            "required": ["authors", "collectionTitle", "title", "year"]         
        },
        "@conference": {
            "title": "@CONFERENCE sub-schema",
            "description": "`@CONFERENCE` entry data model. Inherits from `@inproceedings` but defaults to presentation/symposium descriptors.",
            "$ref": "#/$defs/@inproceedings",
            "properties": {
                "type": { 
                    "$ref": "#/$defs/F_type",
                    "default": "Conference presentation",
                    "description": "Clarifies the presentation medium (e.g., 'Poster presentation', 'Keynote address', 'Symposium speech') for CFF 'speech' or 'conference-paper' mapping."
                }
            }
        },
        "@incollection": {
            "type": "object",
            "title": "@INCOLLECTION sub-schema",
            "description": "`@INCOLLECTION` entries' data model.",
            "$comment": "@IMPORTANT: CFF ignored `series` and `type` for `@incollection`, but both fields are valid in BibTex.",
            "properties": {
                "address": { "$ref": "#/$defs/F_address" },
                "annote": { "$ref": "#/$defs/F_annote" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "chapter": { "$ref": "#/$defs/F_chapter" },
                "collectionTitle": { "$ref": "#/$defs/F_collectionTitle" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "edition": { "$ref": "#/$defs/F_edition" },
                "editors": { "$ref": "#/$defs/F_editors" },
                "issueNumber": { "$ref": "#/$defs/F_issueNumber" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "pages": { "$ref": "#/$defs/F_pages" },
                "publisher": { "$ref": "#/$defs/F_publisher" },
                "title": { "$ref": "#/$defs/F_title" },
                "volume": { "$ref": "#/$defs/F_volume" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },
                "year": { "$ref": "#/$defs/F_year" }
            },
            "required": ["authors", "chapter", "collectionTitle", "title", "publisher", "year"]      
        },
        "@manual": {
            "type": "object",
            "title": "@MANUAL sub-schema",
            "description": "`@MANUAL` entries' data model.",
            "$comment": "Neither BibTex or CFF models accept `pages` for `@manual`, but it is a valid field in APA7 referencing format and grammar.",
            "properties": {
                "address": { "$ref": "#/$defs/F_address" },
                "annote": { "$ref": "#/$defs/F_annote" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "edition": { "$ref": "#/$defs/F_edition" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "organization": { "$ref": "#/$defs/F_organization" },
                "pages": { "$ref": "#/$defs/F_pages" },
                "publisher": { "$ref": "#/$defs/F_publisher" },
                "title": { "$ref": "#/$defs/F_title" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },
                "year": { "$ref": "#/$defs/F_year" }
            },
            "required": ["title"]    
        },
        "@mastersthesis": {
            "type": "object",
            "title": "@MASTERSTHESIS sub-schema",
            "description": "`@MASTERSTHESIS` entry data model.",
            "$comment": "Includes the `type` field to support CFF `thesis-type` and BibLaTeX degree descriptors (e.g., 'Master's thesis', 'MSc Report').",
            "properties": {
                "address": { "$ref": "#/$defs/F_address" },
                "annote": { "$ref": "#/$defs/F_annote" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "institution": { "$ref": "#/$defs/F_institution" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "school": { "$ref": "#/$defs/F_school" },
                "title": { "$ref": "#/$defs/F_title" },
                "type": { 
                    "$ref": "#/$defs/F_type",
                    "default": "Master's thesis",
                    "description": "Specifies the exact degree or thesis type. Essential for mapping to CFF 'thesis-type' or CSLe 'genre'."
                },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },
                "year": { "$ref": "#/$defs/F_year" }
            },
            "required": ["authors", "school", "title", "year"]            
        },
        "@phdthesis": {
            "title": "@PHDTHESIS sub-schema",
            "description": "`@PHDTHESIS` entry data model. Inherits structural properties from `@mastersthesis` while overriding subtype metadata.",
            "$ref": "#/$defs/@mastersthesis",
            "properties": {
                "type": { 
                    "$ref": "#/$defs/F_type",
                    "default": "PhD thesis",
                    "description": "Specifies the exact doctoral degree or dissertation type (e.g., 'PhD thesis', 'Doctoral dissertation'). Essential for CFF 'thesis-type' mapping."
                }
            }
        },
        "@misc": {
            "type": "object",
            "title": "@MISC sub-schema",
            "description": "`@MISC` entries' data model: A fallback type requiring at least a title or author.",
            "properties": {
                "annote": { "$ref": "#/$defs/F_annote" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "howpublished": { "$ref": "#/$defs/F_howpublished" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "title": { "$ref": "#/$defs/F_title" },
                "type": { "$ref": "#/$defs/F_type" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },
                "year": { "$ref": "#/$defs/F_year" }
            },
            
            "anyOf": [
                { "required": ["title"] },
                { "required": ["authors"] }
            ]
        },
        "@techreport": {
            "type": "object",
            "title": "@TECHREPORT sub-schema",
            "description": "`@TECHREPORT` entries' data model.",
            "properties": {
                "address": { "$ref": "#/$defs/F_address" },
                "annote": { "$ref": "#/$defs/F_annote" },
                "authors": { "$ref": "#/$defs/F_authors" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "institution": { "$ref": "#/$defs/F_institution" },
                "issueNumber": { "$ref": "#/$defs/F_issueNumber" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "title": { "$ref": "#/$defs/F_title" },
                "type": { "$ref": "#/$defs/F_type" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },
                "year": { "$ref": "#/$defs/F_year" }
            },
            "required": ["authors", "title", "institution", "year"]
            
        },
        "@proceedings": {
            "type": "object",
            "title": "@PROCEEDINGS sub-schema",
            "description": "`@PROCEEDINGS` entries' data model.",
            "properties": {
                "address": { "$ref": "#/$defs/F_address" },
                "annote": { "$ref": "#/$defs/F_annote" },
                "crossref": { "$ref": "#/$defs/F_crossref" },
                "editors": { "$ref": "#/$defs/F_editors" },
                "issueNumber": { "$ref": "#/$defs/F_issueNumber" },
                "key": { "$ref": "#/$defs/F_key" },
                "month": { "$ref": "#/$defs/F_month" },
                "note": { "$ref": "#/$defs/F_note" },
                "organization": { "$ref": "#/$defs/F_organization" },
                "publisher": { "$ref": "#/$defs/F_publisher" },
                "series": { "$ref": "#/$defs/F_series" },
                "title": { "$ref": "#/$defs/F_title" },
                "type": { "$ref": "#/$defs/F_type" },
                "volume": { "$ref": "#/$defs/F_volume" },
                "webIdentifier": { "$ref": "#/$defs/F_webIdentifier" },
                "year": { "$ref": "#/$defs/F_year" }
            },
            "required": ["title", "year"] 
        },

        "author": {
            "type": "object",
            "description": "Represents either an individual person or a corporate entity.",
            "oneOf": [
                {
                    "title": "Corporate Author",
                    "properties": {
                        "corporateName": {
                            "type": "string"
                        },
                        "corporateAcronym": {
                            "type": "string"
                        }
                    },
                    "required": ["corporateName"]
                    
                },
                {
                    "title": "Individual Author",
                    "properties": {
                        "firstName": {
                            "type": "string"
                        },
                        "middleName": {
                            "type": "string"
                        },
                        "lastName": {
                            "type": "string"
                        },
                        "honorifics": {
                            "enum": ["Dr.", "Prof.", "A/Prof.", "Ph.D.", "Mr.", "Mrs.", "Ms."],
                            "$comment": "Unnecessary but leave as is for now"
                        }
                    },
                    "required": ["firstName", "lastName"]     
              }
            ]
        },
        "doi": {
            "$anchor": "doi",
            "type": "string",
            "pattern": "^(?:https?://(?:dx\\.)?doi\\.org\\/|info:doi\\/|(?i:d\\.?o\\.?i\\.?\\s*:\\s*))?(10\\.\\d{4,9}\\/[-._;()/:a-zA-Z0-9]+)$",
            "description": "DOI (Digital Object Identifier) string format and pattern validation"
        },
        "url": {
            "$anchor": "url",
    
            "type": "string",
            "pattern": "^(https?|ftp)://[^\\s/$.?#].[^\\s]*$",
            "description": "URL string format and pattern validation"
        },
        "standardCiteKey": {
            "type": "array",
            "description": "The Standard String Format of a citeKey - i.e., t-string as an algorithm.",
            "$comment":"standard pattern = 'last name of the first author' + 'year'; note that curretly, 'authors'<type: array> == [ {'author'}, ...].\n\nWe do not have a field the capacity-(?) to retrieve only the first object of an array from the data payload for evaluation at data validation time.",
            "dependentRequired": { },
            "prefixItems":  [
                { "type": "string", "$ref": "#/$defs/F_authors" },
                { "type": ["string", "integer"], "$ref": "#/$defs/F_year" }
            ] 

        }
    }
}
