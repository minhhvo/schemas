{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "A Dictionary and Registry of Astrology Aspect Patterns",
    "$comment": "[Source](https://cafeastrology.com/articles/aspectpatterns.html)",

    "type": "object",
    "properties": {
        "Tsquare": { "$ref": "#$defs/Tsquare" },
        "grandTrine": {},
        "Yod": {},
        "grandSquare": {},
        "grandCross": {},
        "Kite": {},
        "grandSextile": {},
        "pentagram": {},
        "envelope": {},
        "cradle": {},
        "mysticRectangle": {}
    },

    "$defs": {
        "Tsquare": {
            "type": "object",
            "properties": {
                "points": { 
                    "prefixItems": [
                        { "$ref": "#planets" },
                        { "$ref": "#planets" },
                        { "$ref": "#planets" }
                ],
                    "minItems": 3, "maxItems": 3,
                    "uniqueItems": true
                } 
            }
        },
        "grandTrine": {
            "type": "object"
        },
        "Yod": {
            "type": "object"
        },
        "grandSquare": {
            "type": "object"
        },
        "grandCross": {
            "type": "object"
        },
        "Kite": {
            "type": "object"
        },
        "grandSextile": {
            "type": "object"
        },
        "pentagram": {
            "type": "object"
        },
        "envelope": {
            "type": "object"
        },
        "cradle": {
            "type": "object"
        },
        "mysticRectangle": {
            "type": "object"
        },

        "celestialBodies": { 
            "$anchor": "planets",
            "type": "string",
            "enum": [
                "Sun", "Moon", 
                "Mercury", "Venus", "Mars",
                "Jupiter", "Saturn",
                "Uranus", "Neptune", "Pluto"
            ]
        },
        "asteroids": {
            
        },
        "mathematicalPoints": {
            "$anchor": "mathPoints",
            "type": "string",
            "enum": [
                "North Node", ""
            ]
        }

    }
}